LAMMPS (2 Aug 2023 - Update 4)
variable E equal 2.3E11 # Young’s modulus   Pa
variable nu equal 0.314 # Poisson ratio
variable rho equal 1.1E4 # initial mass density   kg/m3
variable rhoclad equal 6550 # initial mass density   kg/m3
variable q1 equal 1 # standard artificial viscosity linear coefficient (0-1)
variable q2 equal 1 # standard artificial viscosity quadratic coefficient (not actually implemented fully)
variable hg equal 0.0 # hourglass control coefficient
variable cp equal 3E2 # heat capacity of material   J/kgK (updated with fix later)
variable k equal 3 # Thermal Conductivity of material   W/mK (updated with fix later)
variable alpha equal 1E-5 # thermal expansion of material
variable T0 equal 500 # rest temperature of material   K
variable EF equal 5E3 # strain failure          #this is far higher to cause no fracture initialy (updated later with fix)
variable HM equal 0 # heat per unit mass     (fixed later)

read_restart restart.file
Reading restart file ...
  restart file = 2 Aug 2023, LAMMPS = 2 Aug 2023
  restoring atom style spooff from restart
  orthogonal box = (-0.0049009816 -0.0049009816 -0.000402) to (0.0049 0.0049 0.000402)
  3 by 5 by 1 MPI processor grid
  restoring pair style hybrid/overlay from restart
  6995 atoms
  read_restart CPU = 0.028 seconds

newton off

fix temp_out_fix out spooff/settemp 0	   #fixes outer temperature. changing 0 value will make temperature have constant rate of change of that value.
fix cp mid spooff/setspecificheat 1 1         #this sets a temperature varying specific heat based on Matpro UO2
fix K mid spooff/setconductivity 1 1	   #this sets a temperature varying conductivity based on Matpro UO2

####################################################################################################
# TIME INTEGRATION
####################################################################################################
#fix dtfix tlsph spooff/adjust_dt 0.01 # dynamically adjust time increment every step   - I turned this off as it doesn't account for the temperature time step limit.
fix integration_fix tlsph spooff/integrate_tlsph limit_velocity 30

####################################################################################################
# SPECIFY TRAJECTORY OUTPUT
####################################################################################################
compute S all spooff/tlsph/stress_cylindrical # Cauchy stress tensor - cylindrical co-ordinate form
compute E all spooff/tlsph/strain_cylindrical # Green-Lagrange strain tensor - cylindrical co-ordinate form
compute nn all spooff/tlsph/num/neighs # number of neighbors for each particle
compute e all spooff/internal/energy #internal thermal energy
compute r all spooff/cylindrical #cylindrical co-ords r theta z
compute conr all spooff/contact/radius # particle contact radius
compute rho all spooff/rho # density (doesn't update)
compute vol all spooff/vol # particle volume (doesn't update)
compute dam all spooff/damage # Calculates 4 damage values:
#1 the percentage of lost neigbhors (0-1)
#2 the average bond degredation (0-1)
#3 the average energy of still connected bonds (only relevant to some failure models)
#4 the actual ascociated damage value (only relevant to track for damage onset based on some failure models)
compute t all spooff/temperature #temperature
compute k all spooff/conductivity #conductivity
compute cp all spooff/specificheat #specific heat
compute Q all spooff/heatflux_cylindrical # heatflux - cylindrical co-ordinate form
compute frac all spooff/failure # calculates the strain failure values per particle
compute EP all spooff/plastic/strain #potential internal energy - not really used for anything just the work done
compute y all spooff/youngs
dump dump_id all custom 1000 dump.LAMMPS id type x y z vx vy vz c_S[1] c_S[2] c_S[4] c_nn c_E[1] c_E[2] c_E[4] c_r[1] c_r[2] c_r[3] c_dam[1] c_dam[2] c_dam[3] c_dam[4] c_e c_conr c_t c_k c_cp c_rho c_frac c_vol c_EP c_y c_Q[1] c_Q[2] c_Q[3]
dump_modify dump_id first yes

#this file is for the bond information. can be imported to ovito throgh the "load trajectory" modification - low damage values e.g 9.67e-5 getting read as 9.67 for some reason?
#file also causing early crashes if the system breaks up too much - needs updating with more particle checks to avoid memory errors
compute pair all damage/local patom1 patom2 damage degredation energy
dump dump2 all local 1000 dump2.LAMMPS c_pair[*]
dump_modify  dump2 colname 1 patom1 colname 2 patom2 colname 3 damage colname 4 degredation colname 5 energy

fix youngs clad spooff/setyoungs 1 2 #set to UO2 thermal dependant youngs modulus from matpro
fix youngs cyl spooff/setyoungs 1 1 #set to UO2 thermal dependant youngs modulus from matpro
WARNING: Replacing a fix, but new group != old group (../modify.cpp:873)

#lots of the pair style values are over written by the fixes to allow temperature dependant properties and easy turing on and off.
pair_style hybrid/overlay  spooff/tlsph spooff/thermal spooff/hertz 1.5

>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========
TLSPH settings
... will never update reference configuration
>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========>>========
pair_coeff 1 1 spooff/tlsph *COMMON ${rho} ${E} ${nu} ${q1} ${q2} ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 ${E} ${nu} ${q1} ${q2} ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 ${nu} ${q1} ${q2} ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 ${q1} ${q2} ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 ${q2} ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 ${hg} ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 ${cp} ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 ${k} ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 3 ${HM} *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 3 0 *STRENGTH_LINEAR *EOS_THERMAL ${T0} ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 3 0 *STRENGTH_LINEAR *EOS_THERMAL 500 ${alpha} *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 3 0 *STRENGTH_LINEAR *EOS_THERMAL 500 1e-05 *FAILURE_MAX_PRINCIPAL_STRESS ${EF} *THERMAL_OFF *END
pair_coeff 1 1 spooff/tlsph *COMMON 11000 230000000000 0.314 1 1 0 300 3 0 *STRENGTH_LINEAR *EOS_THERMAL 500 1e-05 *FAILURE_MAX_PRINCIPAL_STRESS 5000 *THERMAL_OFF *END

